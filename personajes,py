class equipo:
    def __init__(self):
        self.lista_personaje = []

    def Agregar_personaje(self,personaje):
        self.lista_personaje.append(personaje)

    def Mostrar_Estado(self):
        for personaje in self.lista_personaje:
            estado = "vivo"  if personaje.esta_vivo() else "caido"
            print(f"{personaje.nombre} - vida: {personaje.get_vida()} - estado: {estado}")

    def Mostrar_integrantes(self):
        for personaje in self.lista_personaje:
            print(personaje.nombre)

    def vivos(self):
        return [personaje for personaje in self.lista_personaje if personaje.esta_vivo()]


