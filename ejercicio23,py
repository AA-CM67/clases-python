class libro:
    def __init__(self, titulo, categoria, autor):
        self.titulo = titulo
        self.categoria = categoria
        self.autor = autor
        self.p = False

    def prestar (self):
            if  not self.p:
                self.p = True
                return f"el libro{self.titulo} ha sido prestado"
            else:
                return F"el libro{self.titulo} ya esta prestado"
    def devolver (self):
            self.p = False
            return f"el libro {self.titulo} ha sido devuelto"
    def esta_prestado (self):
            return not self.p

