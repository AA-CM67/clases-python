class biblioteca:
    def __init__(self, nombre):
            self.nombre = nombre
            self.libro = []

    def agregar_libros(self, libro):
            self.libro.append(libro)
            return f"el libro {libro.titulo} fue agregado a {self.nombre}"
    
    def mostrar_libro(self):
          if not self.libro:
                return " no hay libros en la biblioteca"
          for l in self.libro:
                estado = "prestado" if l.p else "disponible"
                print(f"- {l.titulo} | {l.autor} | {estado}")

    def buscador_libro(self, titulo):
          for l in self.libro:
                if l.titulo == titulo:
                      return l
                return "libro no encontrado"
          
