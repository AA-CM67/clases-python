import random

# generar un número aleatorio entre 1 y 100
numero_secreto = random.randint(1,100)

intentos_maximo = 9


print("=== juego adivinar el numero ===")
print("debe adivinar un numero entere 1 y 100.")
print("tiene", intentos_maximo, "intentos. n")

for intento in range(1, intentos_maximo + 1):
    numero = int(input(f" intento {intento}: ingresa tu numero:"))
    if numero == numero_secreto:
        print("¡Correcto! Adivinaste el número.")
        print("lo logrates en ",intento, "intentos.")
        break

    elif numero < numero_secreto:
        print("📈 El número es mayor.\n")
    else:
        print("📉 El número es menor.\n")
else:
        print("\n❌ Se acabaron los intentos.")
        print(f"El número secreto era {numero_secreto}.")